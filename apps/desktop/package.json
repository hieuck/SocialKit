    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "electron": "^42.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.3"
